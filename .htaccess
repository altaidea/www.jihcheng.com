# ================================================
# 🔒 檔案隔離 (Apache 2.4+ 語法)
# ================================================
<Files "jihcheng_config_202603.dat">
    Order allow,deny
    Deny from all
</Files>
# ================================================
# 🚧 關閉 MultiViews，避免內容協商干擾
# ================================================
Options -MultiViews
RewriteEngine On

# ⭐ 自動適應路徑：如果您在子目錄，請確保 .htaccess 放在該子目錄內
# 如果發生 500 錯誤，可嘗試手動取消註解下一行並調整為您的子目錄路徑
# RewriteBase /demo/www.jihcheng.com/

# ==============================================
# 🔁 語系強制定向 (SEO 核心)
# ==============================================
# ⭐ 將 /zh/ 轉為 /zh-TW/，排除實體檔案避免死循環
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^zh/(.*)$ zh-TW/$1 [R=301,L,NC]

# ==============================================
# 🔁 舊網址 → 新網址
# ==============================================

# ==============================
# 🧱 維護模式：若 maintenance.html 存在 → 導向維護頁
RewriteCond %{REQUEST_URI} !^/maintenance\.html$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/maintenance.html -f
RewriteRule ^.*$ /maintenance.html [R=302,L]
# ==============================

############################################
# A) 在「測試機 altaweb02.com.tw」上 → 全部導向正式網域
#    僅測試主機時才執行，不影響正式站
############################################

# 放行 ACME 憑證與 Cloudflare Email Obfuscation
RewriteCond %{REQUEST_URI} ^/(\.well-known/|cdn-cgi/) [NC]
RewriteRule ^ - [L]

# 放行 error 與 captcha
RewriteRule ^(error|captcha)\.php$ - [L]

# === 當測試站直接請求 .php → 對應 .html 並導向正式站 ===
