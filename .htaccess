# ========== 追加部分 END ===================================

############################################
# B) 正式站 規範化（網址強制 .html）
############################################

# 實體檔案與目錄 → 直接放行，不處理
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 1️⃣ 將 .php 對外轉成 .html (例如 contact.php -> contact.html)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.php(?:[?\s]|$) [NC]
RewriteCond %1 !^index$ [NC]
RewriteRule ^ %1.html [R=301,L,QSD]

# 2️⃣ 語系首頁規範化 (支援 zh-TW)
# 如果網址是 /zh-TW/ 或 /zh-TW (不分大小寫)，強制 301 導向到 home.html
RewriteRule ^(zh-TW|en)/?$ $1/home.html [R=301,L,NC]

# 原有的首頁補完 (例如 /zh-TW/home -> /zh-TW/home.html)
RewriteRule ^(zh-TW|en|cn|ko)/home/?$ $1/home.html [R=301,L,NC]

# 3️⃣ 搜尋頁面 (使用 [L] 停止後續匹配)
RewriteRule ^(zh-TW|en|cn|ko)/search/(.+)$ index.php?path=$1/search&keyword=$2 [L,QSA,B]

# 4️⃣ 核心路由：將 .html 請求交給 index.php
# 使用 [DPI] 旗標防止子目錄路徑在某些伺服器配置下重複疊加
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)\.html$ index.php?path=$1 [L,QSA]

# 5️⃣ 萬用 Fallback：其餘非檔案請求統一交給 index.php
# 確保 /zh/products/series 這種不帶 .html 的也能進入路由
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.html$
RewriteRule ^(.*)$ index.php?path=$1 [L,QSA]