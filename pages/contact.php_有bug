<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('submitBtn');
    const responseInput = document.getElementById('recaptchaResponse');

    if (!form || !submitBtn) return;
    
    form.addEventListener('submit', function(e) {
      // --- A. 基本驗證 ---
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      
      e.preventDefault(); // 攔截預設送出動作

      // --- B. 防連點：立即啟動 UI 鎖定 ---
      const originalText = submitBtn.innerHTML; // 備份原本文字
      const loadingText = submitBtn.getAttribute('data-loading');
      
      submitBtn.disabled = true; // 鎖定按鈕不可點擊
      // 加入 Spinner 動畫 + 讀取中文字
      submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> ${loadingText}`;

      // --- C. 安全定時器 (防止 Google API 沒回應) ---
      const safetyTimeout = setTimeout(function() {
        if (submitBtn.disabled) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          alert("Connection slow, please try again.");
        }
      }, 10000); // 10秒後若沒跳轉則解鎖

      // --- D. 執行 reCAPTCHA ---
      grecaptcha.ready(function() {
        grecaptcha.execute('6LepoHUUAAAAAJ_yBEpIDCIeIci7Oys3V7hVzve8', {
          action: 'contact'
        }).then(function(token) {
          clearTimeout(safetyTimeout); // 成功取得 Token，取消超時警告
          
          if (responseInput) {
            responseInput.value = token;
          }
          
          // --- E. 正式送出 ---
          // 注意：使用原生 form.submit() 不會再次觸發此 submit 監聽器，避免無限迴圈
          form.submit(); 
          
        }).catch(function(error) {
          // 若 reCAPTCHA 拋出錯誤
          clearTimeout(safetyTimeout);
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          console.error('reCAPTCHA Error:', error);
          alert("Security verification failed. Please check your network.");
        });
      });
    });
  });
</script>

